#!/bin/bash

# Toggle the laptop touchpad on/off.
# Hides the cursor when disabled, shows it when re-enabled.

PATHS_CACHE="/run/touchpad_inhibited_paths"

# Toggle via polkit (writes to sysfs, requires root)
pkexec "$OMARCHY_PATH/default/touchpad/toggle-impl"

# Read new state after toggle
if [[ -f $PATHS_CACHE ]] && [[ -s $PATHS_CACHE ]]; then
  first_file=$(head -n 1 "$PATHS_CACHE")
  new_state=$(cat "$first_file" 2>/dev/null || echo "0")
else
  new_state="0"
fi

if [[ $new_state == "0" ]]; then
  # Touchpad re-enabled — show cursor
  hyprctl keyword cursor:inactive_timeout 0 >/dev/null 2>&1
  notify-send -t 3000 "󰟸   Touchpad enabled"
else
  # Touchpad disabled — hide cursor after 1s of inactivity
  hyprctl keyword cursor:inactive_timeout 1 >/dev/null 2>&1
  notify-send -t 3000 "󰤳   Touchpad disabled"
fi

pkill -RTMIN+11 waybar
