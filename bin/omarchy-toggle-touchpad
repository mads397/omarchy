#!/bin/bash

# Toggle the laptop touchpad on/off.
# Hides and parks the cursor when disabled, restores when re-enabled.

CURSOR_STATE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/touchpad_cursor_pos"
PATHS_CACHE="/run/touchpad_inhibited_paths"

# Check current state before toggle
if [[ -f $PATHS_CACHE ]] && [[ -s $PATHS_CACHE ]]; then
  first_file=$(head -n 1 "$PATHS_CACHE")
  current_state=$(cat "$first_file" 2>/dev/null || echo "0")
else
  current_state="0"
fi

if [[ $current_state == "0" ]]; then
  # About to disable — save cursor position
  hyprctl cursorpos 2>/dev/null | tr -d ',' > "$CURSOR_STATE"
fi

# Toggle via polkit (writes to sysfs, requires root)
pkexec "$OMARCHY_PATH/default/touchpad/toggle-impl"

# Read new state after toggle
if [[ -f $PATHS_CACHE ]] && [[ -s $PATHS_CACHE ]]; then
  first_file=$(head -n 1 "$PATHS_CACHE")
  new_state=$(cat "$first_file" 2>/dev/null || echo "0")
else
  new_state="0"
fi

if [[ $new_state == "0" ]]; then
  # Touchpad re-enabled — move cursor back, then show it
  if [[ -f $CURSOR_STATE ]]; then
    read -r x y < "$CURSOR_STATE"
    hyprctl dispatch movecursor "$x" "$y" >/dev/null 2>&1
    rm -f "$CURSOR_STATE"
  fi
  hyprctl keyword cursor:inactive_timeout 0 >/dev/null 2>&1
  notify-send -t 2000 "󰟸   Touchpad enabled"
else
  # Touchpad disabled — hide cursor, then park it off-screen
  hyprctl keyword cursor:inactive_timeout 0.001 >/dev/null 2>&1
  sleep 0.05
  hyprctl dispatch movecursor 9999 9999 >/dev/null 2>&1
  notify-send -t 2000 "󰤳   Touchpad disabled"
fi

pkill -RTMIN+11 waybar
